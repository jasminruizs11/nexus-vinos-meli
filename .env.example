# Plantilla de variables de entorno para NEXUS Vinos
   # Copiá este archivo como ".env" y completá tus propios valores reales.
   # NUNCA subas el archivo ".env" (con tus credenciales reales) al repositorio.

   # App ID de tu aplicación creada en https://developers.mercadolibre.com.ar/
   MELI_APP_ID=tu_app_id_aca

   # Client Secret de tu aplicación (mantenelo siempre privado)
   MELI_SECRET=tu_client_secret_aca
